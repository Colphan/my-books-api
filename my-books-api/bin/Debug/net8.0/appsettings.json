{
  "ConnectionStrings": {
    "DefaultConnectionString": "Data Source=my-books.db"
  },

  "Serilog": {
  "MinimumLevel": "Information",
  "WriteTo": [
    {
      "Name": "File",
      "Args": {
        "path": "Logs/app-log.txt",
        "rollingInterval": "Day",
        "outputTemplate": "{Timestamp} [{Level}] - Message: {Message}{NewLine}{Exception}"
      }
    },
    {
      "Name": "SQLite",
      "Args": {
        "sqliteDbPath": "my-books.db",
        "tableName": "Logs"
      }
    }
  ]
},

  

  "AllowedHosts": "*"
}
